# Copy this file to .env and fill in your Deepgram API key.
# You can reuse the key from /home/alex/projects/deepgram-stt/.env
DEEPGRAM_API_KEY=

# Optional: default analysis/transcription language profile (en, generic, ja, ...).
PRACTICE_LANGUAGE=en

# OpenAI — needed only for the opt-in `analyze.py --review` LLM error review.
# You can copy the key from /home/alex/projects/questionarie-master/.env
OPENAI_KEY=
# Optional: override the review model (default gpt-5.5).
OPENAI_MODEL=gpt-5.5

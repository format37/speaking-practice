# Copy this file to .env and fill in your Deepgram API key.
# You can reuse the key from /home/alex/projects/deepgram-stt/.env
DEEPGRAM_API_KEY=

# Optional: FALLBACK language profile (en, generic, ja, ru, ...). The primary
# source is each student's data/<student>/config.yaml `language`; this is only
# used when that is missing and no --language is passed.
PRACTICE_LANGUAGE=en

# Opt-in `analyze.py --review` LLM error review.
# Backend: "claude" (default) uses your local Claude subscription via the Claude
# Agent SDK — NO API key and NO per-token cost. "openai" uses the paid API.
REVIEW_BACKEND=claude
# Only needed when REVIEW_BACKEND=openai (paid API).
OPENAI_KEY=
OPENAI_MODEL=gpt-5.5
